# Standard Z-Axis Deuteron Beam Source
# Optimized for CH2 target at origin
/gps/source/intensity 1.0
/gps/particle deuteron

# Position: Point origin slightly upstream of the target
/gps/pos/type Point
/gps/pos/centre 0 0 -5 cm

# Direction: Along +Z towards target
/gps/direction 0 0 1

# Energy: Monoenergetic 400 MeV (example energy)
/gps/ene/type Mono
/gps/ene/mono 400 MeV
